{
  "name": "@jameswomack/mluxe",
  "version": "1.0.0-alpha.0",
  "description": "Apple MLX wrapper — local LLM inference on Apple Silicon from Node.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "mlx",
    "apple-silicon",
    "llm",
    "inference",
    "metal"
  ],
  "author": "James Womack",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=24.16.0",
    "pnpm": ">=9.7.0"
  }
}
